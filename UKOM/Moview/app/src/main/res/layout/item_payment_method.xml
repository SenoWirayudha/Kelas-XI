<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_payment_method">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Logo placeholder -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="52dp"
            android:layout_height="32dp"
            app:cardBackgroundColor="#252A34"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tv_payment_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="DANA"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_payment_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DANA"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_promo_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kartu Kredit/Debit Tersedia"
                    android:textColor="#4A90E2"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/bg_promo_label"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_payment_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dapatkan diskon Rp20.000"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <RadioButton
            android:id="@+id/rb_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/accent_blue" />
    </LinearLayout>
</LinearLayout>
