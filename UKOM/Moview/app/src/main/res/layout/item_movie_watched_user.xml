<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dark_surface"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Avatar"
            android:scaleType="centerCrop"
            tools:src="@drawable/ic_default_profile" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_username"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/card_avatar"
        app:layout_constraintEnd_toStartOf="@id/layout_indicators"
        app:layout_constraintTop_toTopOf="@id/card_avatar"
        app:layout_constraintBottom_toBottomOf="@id/card_avatar"
        tools:text="jaben0" />

    <LinearLayout
        android:id="@+id/layout_indicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/card_avatar"
        app:layout_constraintBottom_toBottomOf="@id/card_avatar"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_rating_stars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/star_green"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="★★★★" />

        <ImageView
            android:id="@+id/iv_like"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_heart_filled"
            android:contentDescription="Liked"
            android:visibility="gone"
            app:tint="@color/orange" />

        <ImageView
            android:id="@+id/iv_review"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_review"
            android:contentDescription="Has review"
            android:visibility="gone"
            app:tint="@color/text_secondary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
