<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="60dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <FrameLayout
        android:id="@+id/layout_avatar_container"
        android:layout_width="52dp"
        android:layout_height="52dp">

        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Avatar"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_default_profile" />
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/iv_badge_action"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="end|top"
            android:src="@drawable/ic_review"
            android:contentDescription="Has review"
            android:background="@drawable/circle_background_dark"
            android:padding="4dp"
            app:tint="@color/text_secondary" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_stars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:singleLine="true"
        android:textColor="@color/star_green"
        android:textSize="11sp"
        tools:text="★★★★" />

</LinearLayout>
