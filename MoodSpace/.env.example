NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:4000/api
VITE_API_BASE_URL=http://localhost:4000/api

DATABASE_URL=postgres://postgres:postgres@localhost:5432/moodspace

JWT_ACCESS_SECRET=change-me-access-secret
ACCESS_TOKEN_TTL=15m

REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=moodspace_refresh
COOKIE_SECURE=false

STORAGE_PROVIDER=supabase

MEDIA_PUBLIC_BASE_URL=

# External image providers for Browse Asset discovery
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
TMDB_API_KEY=

# Google Fonts API (get key at https://console.cloud.google.com/apis/credentials)
VITE_GOOGLE_FONTS_API_KEY=your_google_fonts_api_key
